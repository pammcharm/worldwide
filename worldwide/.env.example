# WorldWide Configuration
# Copy this file to .env and fill in your actual values

# Core Django Settings
SECRET_KEY=change-me-in-production-secret-key-here-use-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com,www.yourdomain.com

# Database Configuration
# For local development:
# DATABASE_URL=sqlite:///db.sqlite3
# For Supabase Postgres (production):
# DATABASE_URL=postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/worldwide

# Supabase Auth (Optional - for OAuth login)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SECRET_KEY=your-server-secret-key

# Stripe Payment Gateway
STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key
STRIPE_SECRET_KEY=sk_live_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Paypack Rwanda Mobile Money
PAYPACK_CLIENT_ID=your-paypack-client-id
PAYPACK_CLIENT_SECRET=your-paypack-client-secret
PAYPACK_BASE_URL=https://payments.paypack.rw/api
PAYPACK_WEBHOOK_MODE=production
PAYPACK_WEBHOOK_SECRET=your-paypack-webhook-signing-secret
PAYPACK_TIMEOUT_SECONDS=20

# Email Configuration (for order confirmations, etc.)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password

# Redis/Celery (optional, for async tasks)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# Security Settings (enable in production)
SECURE_SSL_REDIRECT=True
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SECURE=True
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_TYPE_NOSNIFF=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Storage Configuration
# Choose storage backend:
# - false: Local filesystem (default, good for Render with persistent volume)
# - true: S3/AWS (good for distributed systems)
USE_S3_STORAGE=False

# S3 Storage Configuration (only if USE_S3_STORAGE=True)
# For Supabase Storage, use Supabase S3-compatible endpoint:
# AWS_STORAGE_BUCKET_NAME=your-supabase-project.storage.supabase.co
# AWS_S3_REGION_NAME=us-east-1 (or your region)
# AWS_S3_CUSTOM_DOMAIN=cdn.yourdomain.com (optional CDN domain)
# AWS_S3_ACCESS_KEY_ID=your-supabase-access-key
# AWS_S3_SECRET_ACCESS_KEY=your-supabase-secret-key
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
AWS_S3_USE_SSL=True
AWS_S3_VERIFY=True

# Use Supabase for database instead of local PostgreSQL (Render deployment)
USE_DIRECT_DATABASE_URL=False


